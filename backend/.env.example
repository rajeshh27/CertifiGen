# =============================================
#   CertifiGen Backend — Environment Variables
#   Copy this file to .env and fill in values
# =============================================

# Port (Render sets this automatically — leave blank on Render)
PORT=5000

# Your deployed Vercel frontend URL (replace with your actual URL)
FRONTEND_URL=https://your-app-name.vercel.app

# Max upload size in MB
MAX_FILE_SIZE_MB=5
